{
  "name": "assetflow-backend",
  "version": "1.0.0",
  "description": "AssetFlow Enterprise Asset ERP Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "ts-node src/server.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "seed:make": "knex seed:make --knexfile knexfile.ts",
    "seed:run": "knex seed:run --knexfile knexfile.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "nodemon": "^3.1.4"
  }
}
